{
  "name": "blackout_bench",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/web",
    "apps/runner",
    "packages/shared"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:runner": "npm --workspace apps/runner run dev",
    "build": "npm --workspace apps/web run build && npm --workspace apps/runner run build",
    "lint": "npm --workspace apps/web run lint",
    "test": "npm --workspace apps/runner run test"
  }
}
